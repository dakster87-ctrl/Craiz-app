# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# Your Stripe Payment Link URL (create at dashboard.stripe.com → Payment Links)
# This is the page users land on to subscribe
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link-here

# Monthly price in dollars shown on the paywall (e.g. 9.99)
VITE_PRICE_MONTHLY=9.99
VITE_PRICE_YEARLY=79.99

# ─── Stripe Webhook (server-side only, set in Vercel dashboard) ───────────────
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_SECRET_KEY=sk_live_your-secret-key-here

# ─── Supabase Service Role (server-side only, set in Vercel dashboard) ────────
# Get from: Supabase → Settings → API → service_role key (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
